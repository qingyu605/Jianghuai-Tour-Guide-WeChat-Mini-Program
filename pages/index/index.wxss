.banner-container {
  width: 100%;
}

.banner-image {
  width: 100%;
  height: 300rpx;
  object-fit: cover;
}

.features-container {
  margin: 20rpx;
}

.features-grid {
  display: flex;
  flex-wrap: wrap;
}

.feature-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.feature-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 10rpx;
}

.feature-name {
  font-size: 26rpx;
  color: #333;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx;
  margin-top: 30rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.more-btn {
  font-size: 28rpx;
  color: #1E88E5;
}

.attractions-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 10rpx;
}

.attraction-card {
  width: 50%;
  padding: 10rpx;
  box-sizing: border-box;
}

.attraction-image {
  width: 100%;
  height: 200rpx;
  border-radius: 8rpx;
  object-fit: cover;
}

.attraction-info {
  padding: 10rpx;
}

.attraction-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 5rpx;
}

.attraction-location {
  display: block;
  margin-bottom: 8rpx;
}

.attraction-level {
  display: flex;
  gap: 8rpx;
}

.level-tag {
  font-size: 24rpx;
  background-color: #FF9800;
  color: white;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

.category-tag {
  font-size: 24rpx;
  background-color: #E0E0E0;
  color: #666;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

.route-item {
  display: flex;
  padding: 15rpx;
}

.route-image {
  width: 200rpx;
  height: 150rpx;
  border-radius: 8rpx;
  object-fit: cover;
}

.route-info {
  flex: 1;
  padding-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.route-name {
  margin-bottom: 5rpx;
}

.route-days {
  margin-bottom: 10rpx;
}
