.hero-card {
  position: relative;
  margin-top: 8rpx;
  overflow: hidden;
  border-radius: 18rpx;
}

.hero-swiper {
  width: 100%;
  height: 280rpx;
}

.hero-image {
  width: 100%;
  height: 280rpx;
}

.hero-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 90rpx 20rpx 18rpx;
  background: linear-gradient(180deg, rgba(5, 19, 43, 0) 0%, rgba(5, 19, 43, 0.76) 100%);
}

.hero {
  padding: 26rpx 30rpx 10rpx;
}

.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
}

.hero-subtitle {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 24rpx;
}

.hero-skeleton {
  height: 260rpx;
}

.banner-container {
  margin-top: 10rpx;
}

.banner-image {
  width: 100%;
  height: 290rpx;
  border-radius: 20rpx;
}

.features-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 10rpx;
}

.stats-strip {
  display: flex;
  padding: 20rpx 10rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f4f82;
}

.stat-label {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #6f849d;
}

.notice-card {
  padding: 20rpx;
}

.notice-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f3858;
}

.notice-item {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #5f7693;
  line-height: 1.6;
}

.city-grid {
  display: flex;
  gap: 12rpx;
  padding: 0 20rpx 20rpx;
}

.city-card {
  flex: 1;
  padding: 18rpx;
}

.city-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #20466f;
}

.city-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #6e829a;
  line-height: 1.5;
}

.feature-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.feature-icon-wrap {
  width: 84rpx;
  height: 84rpx;
  border-radius: 42rpx;
  background-color: #eef5ff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature-icon {
  width: 46rpx;
  height: 46rpx;
}

.feature-name {
  font-size: 24rpx;
  color: #35516f;
  margin-top: 8rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1b365a;
}

.more-btn {
  display: flex;
  align-items: center;
}

.more-btn-label {
  font-size: 24rpx;
  color: #0b7de5;
  line-height: 1.2;
}

.attractions-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 10rpx 8rpx;
}

.attraction-card {
  width: calc(50% - 20rpx);
  margin: 10rpx;
  background-color: #f5f6f8;
  border-radius: 22rpx;
  box-shadow: none;
}

.attraction-image {
  width: 100%;
  height: 160rpx;
  border-top-left-radius: 22rpx;
  border-top-right-radius: 22rpx;
}

.attraction-info {
  padding: 14rpx 14rpx 16rpx;
}

.attraction-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.attraction-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1d2f48;
}

.level-pill {
  font-size: 20rpx;
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  background: #f2b64c;
}

.attraction-location {
  display: block;
  font-size: 24rpx;
  color: #637995;
  margin-top: 8rpx;
}

.category-pill {
  display: inline-block;
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #6f87a5;
  background: #e8edf4;
  border-radius: 20rpx;
  padding: 4rpx 12rpx;
}

.routes-list {
  padding: 0 10rpx 20rpx;
}

.route-item {
  display: flex;
  margin: 10rpx;
}

.route-image {
  width: 210rpx;
  height: 160rpx;
}

.route-info {
  flex: 1;
  padding: 14rpx 14rpx 14rpx 20rpx;
}

.route-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f3655;
}

.route-meta {
  display: block;
  margin-top: 6rpx;
  color: #0b7de5;
  font-size: 24rpx;
}

.route-desc {
  margin-top: 10rpx;
  color: #6d8099;
  font-size: 24rpx;
}

.line {
  border-radius: 12rpx;
  height: 24rpx;
}

.line.long {
  width: 92%;
}

.line.short {
  width: 58%;
}
