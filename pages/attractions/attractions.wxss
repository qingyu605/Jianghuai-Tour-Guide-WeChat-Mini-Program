.search-container {
  background-color: white;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 60rpx;
  padding: 10rpx 20rpx;
}

.search-icon {
  margin-right: 10rpx;
}

.search-input {
  flex: 1;
  height: 60rpx;
  font-size: 28rpx;
  background-color: transparent;
}

.clear-icon {
  margin-left: 10rpx;
}

.categories-container {
  background-color: white;
  padding: 10rpx 0;
  border-bottom: 1px solid #eee;
}

.categories-scroll {
  width: 100%;
  white-space: nowrap;
}

.categories-wrapper {
  display: inline-flex;
  padding: 0 20rpx;
}

.category-item {
  padding: 10rpx 25rpx;
  margin: 0 5rpx;
  font-size: 28rpx;
  border-radius: 60rpx;
}

.category-item.active {
  background-color: #1E88E5;
  color: white;
}

.attractions-list {
  flex: 1;
  overflow-y: auto;
}

.attraction-item {
  position: relative;
  padding: 20rpx;
}

.item-content {
  display: flex;
}

.attraction-image {
  width: 200rpx;
  height: 150rpx;
  border-radius: 8rpx;
  object-fit: cover;
}

.attraction-info {
  flex: 1;
  padding-left: 20rpx;
}

.info-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.attraction-name {
  font-weight: bold;
}

.level-tag {
  font-size: 24rpx;
  background-color: #FF9800;
  color: white;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

.info-bottom {
  display: flex;
  gap: 10rpx;
  align-items: center;
}

.category-tag {
  font-size: 24rpx;
  background-color: #E0E0E0;
  color: #666;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

.distance-tag {
  font-size: 24rpx;
  color: #1E88E5;
}

.favorite-btn {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 150rpx;
  height: 150rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
}
