<view class="container">
  <view class="page-title">{{pageTitle}}</view>
  
  <!-- 搜索框 -->
  <view class="search-container p-20">
    <view class="search-box">
      <icon type="search" size="28" color="#999" class="search-icon"></icon>
      <input 
        type="text" 
        placeholder="搜索景点或地点" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        class="search-input"
      ></input>
      <icon 
        type="clear" 
        size="24" 
        color="#999" 
        class="clear-icon" 
        wx:if="{{searchKeyword}}"
        bindtap="clearSearch"
      ></icon>
    </view>
  </view>
  
  <!-- 分类筛选 -->
  <view class="categories-container">
    <scroll-view scroll-x="true" class="categories-scroll">
      <view class="categories-wrapper">
        <block wx:for="{{categories}}" wx:key="id">
          <view 
            class="category-item {{selectedCategory === item.name ? 'active' : ''}}"
            bindtap="selectCategory"
            data-category="{{item.name}}"
          >
            {{item.name}}
          </view>
        </block>
      </view>
    </scroll-view>
  </view>
  
  <!-- 景点列表 -->
  <view class="attractions-list">
    <block wx:for="{{filteredAttractions}}" wx:key="id">
      <view class="attraction-item card">
        <view class="item-content" bindtap="navigateToDetail" data-id="{{item.id}}">
          <image src="{{item.image}}" mode="widthFix" class="attraction-image"></image>
          <view class="attraction-info">
            <view class="info-top">
              <text class="attraction-name font-lg">{{item.name}}</text>
              <text class="level-tag">{{item.level}}</text>
            </view>
            <text class="attraction-location color-gray font-sm">{{item.location}}</text>
            <text class="attraction-desc color-lightgray font-sm line-clamp-2 mt-10">{{item.description}}</text>
            <view class="info-bottom mt-10">
              <text class="category-tag">{{item.category}}</text>
              <text class="distance-tag" wx:if="{{item.distance}}">{{item.distance.toFixed(1)}} 公里</text>
            </view>
          </view>
        </view>
        <view 
          class="favorite-btn" 
          bindtap="toggleFavorite" 
          data-id="{{item.id}}"
        >
          <icon 
            type="{{isFavorite(item.id) ? 'star' : 'star-o'}}" 
            size="30" 
            color="{{isFavorite(item.id) ? '#FFD700' : '#999'}}"
          ></icon>
        </view>
      </view>
    </block>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{filteredAttractions.length === 0}}">
      <image src="/images/icons/empty.png" class="empty-icon"></image>
      <text class="empty-text">未找到相关景点</text>
    </view>
  </view>
</view>
