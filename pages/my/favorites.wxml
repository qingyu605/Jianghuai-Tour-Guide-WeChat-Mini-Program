<view class="container" bindtap="clearTextSelection">
  <block wx:if="{{isLoading}}">
    <view class="card p-20"><view class="skeleton item-skeleton"></view></view>
    <view class="card p-20"><view class="skeleton item-skeleton"></view></view>
  </block>

  <view wx:else>
    <block wx:for="{{favorites}}" wx:key="id">
      <view class="asset-item card pressable fade-in">
        <view class="item-content" bindtap="navigateToDetail" data-id="{{item.id}}">
          <image src="{{item.image}}" mode="aspectFill" class="item-image"></image>
          <view class="item-info">
            <text user-select="{{allowTextSelect}}" class="item-name">{{item.name}}</text>
            <text user-select="{{allowTextSelect}}" class="item-sub">{{item.location}}</text>
            <text user-select="{{allowTextSelect}}" class="item-time">收藏于 {{item.addTimeText}}</text>
          </view>
        </view>
        <view class="delete-chip pressable" bindtap="deleteFavorite" data-id="{{item.id}}">
          <text user-select="{{allowTextSelect}}">删除</text>
        </view>
      </view>
    </block>

    <view class="empty-state" wx:if="{{favorites.length === 0}}">
      <image src="/images/icons/empty-favorite.png" class="empty-icon"></image>
      <text user-select="{{allowTextSelect}}" class="empty-text">暂无收藏景点</text>
    </view>
  </view>
</view>
