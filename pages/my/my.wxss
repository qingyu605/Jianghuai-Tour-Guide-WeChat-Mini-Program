.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.avatar {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
}

.nickname {
  font-weight: bold;
  color: #333;
}

.login-btn {
  width: 60%;
}

.functions-container {
  margin-top: 20rpx;
}

.function-item {
  display: flex;
  align-items: center;
  padding: 25rpx 30rpx;
  border-bottom: 1px solid #f5f5f5;
}

.function-icon {
  margin-right: 20rpx;
}

.function-name {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

.tabs-header {
  display: flex;
  background-color: white;
  border-bottom: 1px solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 25rpx 0;
  font-size: 32rpx;
  position: relative;
}

.tab-item.active {
  color: #1E88E5;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 4rpx;
  background-color: #1E88E5;
}

.tab-content {
  flex: 1;
  overflow-y: auto;
}

.favorite-item, .saved-route-item {
  position: relative;
  padding: 20rpx;
}

.item-content {
  display: flex;
}

.item-image {
  width: 150rpx;
  height: 110rpx;
  border-radius: 8rpx;
  object-fit: cover;
}

.item-info {
  flex: 1;
  padding-left: 20rpx;
}

.item-name {
  font-weight: bold;
}

.item-tags {
  display: flex;
  gap: 10rpx;
}

.level-tag {
  font-size: 24rpx;
  background-color: #FF9800;
  color: white;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

.category-tag {
  font-size: 24rpx;
  background-color: #E0E0E0;
  color: #666;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

.delete-btn {
  position: absolute;
  top: 50%;
  right: 30rpx;
  transform: translateY(-50%);
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 150rpx;
  height: 150rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
}

.empty-desc {
  font-size: 26rpx;
  text-align: center;
  max-width: 400rpx;
}
