.image-container {
  position: relative;
  width: 100%;
}

.main-image {
  width: 100%;
  height: 400rpx;
  object-fit:cover;
}

.image-nav {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: space-between;
  pointer-events: none;
}

.image-btn {
  width: 80rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.3);
  pointer-events: auto;
}

.image-counter {
  position: absolute;
  bottom: 10rpx;
  right: 10rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: white;
  font-size: 26rpx;
  padding: 5rpx 10rpx;
  border-radius: 4rpx;
}

.favorite-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.info-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.attraction-name {
  font-weight: bold;
}

.level-tag {
  font-size: 26rpx;
  background-color: #FF9800;
  color: white;
  padding: 3rpx 10rpx;
  border-radius: 4rpx;
}

.location-info {
  display: flex;
  align-items: center;
}

.location-text {
  margin-left: 10rpx;
  font-size: 30rpx;
}

.category-tag {
  display: inline-block;
  font-size: 26rpx;
  background-color: #E0E0E0;
  color: #666;
  padding: 3rpx 10rpx;
  border-radius: 4rpx;
}

.section-title {
  font-weight: bold;
  color: #333;
  padding-bottom: 10rpx;
  border-bottom: 1px solid #eee;
}

.description {
  line-height: 1.6;
  font-size: 30rpx;
}

.info-item {
  display: flex;
}

.info-label {
  color: #333;
  font-weight: 500;
  width: 160rpx;
}

.info-value {
  flex: 1;
}

.function-buttons {
  background-color: white;
}

.btn-group {
  display: flex;
  gap: 30rpx;
}

.audio-control, .location-btn {
  flex: 1;
  background-color: #1E88E5;
  color: white;
  border-radius: 8rpx;
  padding: 20rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.audio-icon, .location-icon {
  margin-right: 10rpx;
}
