/* 路线列表样式 */
.route-item {
  display: flex;
  padding: 20rpx;
}

.route-image {
  width: 200rpx;
  height: 150rpx;
  border-radius: 8rpx;
  object-fit: cover;
}

.route-info {
  flex: 1;
  padding-left: 20rpx;
}

.route-name {
  font-weight: bold;
}

.attractions-preview {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  align-items: center;
}

.preview-label {
  white-space: nowrap;
}

.attraction-tag {
  background-color: #E3F2FD;
  color: #1E88E5;
  padding: 5rpx 15rpx;
  border-radius: 60rpx;
  font-size: 26rpx;
}

/* 路线详情样式 */
.detail-image {
  width: 100%;
  height: 300rpx;
  object-fit: cover;
}

.route-name {
  font-size: 36rpx;
  font-weight: bold;
}

.save-icon {
  margin-right: 10rpx;
}

.section-title {
  font-weight: bold;
  color: #333;
  padding-bottom: 10rpx;
  border-bottom: 1px solid #eee;
}

.attraction-item {
  padding: 15rpx 0;
  border-bottom: 1px solid #f5f5f5;
}

.attraction-icon {
  vertical-align: middle;
  margin-right: 10rpx;
}

.attraction-name {
  font-size: 30rpx;
  color: #333;
}

.attraction-location {
  display: block;
  margin-left: 38rpx;
  margin-top: 5rpx;
}

.itinerary-item {
  display: flex;
  margin-bottom: 20rpx;
}

.day-mark {
  width: 50rpx;
  height: 50rpx;
  background-color: #1E88E5;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.itinerary-content {
  flex: 1;
  line-height: 1.6;
}
