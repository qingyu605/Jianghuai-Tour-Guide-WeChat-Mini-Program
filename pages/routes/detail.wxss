.detail-image {
  width: calc(100% - 40rpx);
  margin: 20rpx;
  height: 330rpx;
  border-radius: 20rpx;
}

.route-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f395b;
}

.route-days {
  color: #0b7de5;
  font-size: 26rpx;
}

.route-desc {
  color: #6d829c;
  line-height: 1.7;
  font-size: 26rpx;
}

.section-title {
  font-weight: 700;
  color: #1f395b;
  font-size: 30rpx;
}

.attraction-item {
  padding: 14rpx 0;
  border-bottom: 1px solid #edf2f8;
}

.attraction-icon {
  vertical-align: middle;
  margin-right: 10rpx;
}

.attraction-name {
  font-size: 28rpx;
  color: #213a5c;
}

.attraction-location {
  display: block;
  margin-left: 34rpx;
  margin-top: 6rpx;
  color: #7b8ea5;
  font-size: 24rpx;
}

.itinerary-item {
  display: flex;
  margin-bottom: 20rpx;
}

.day-mark {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, #1a7fe7 0%, #0f65c8 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.itinerary-content {
  flex: 1;
  line-height: 1.7;
  color: #5f7592;
  font-size: 25rpx;
}

.cover-skeleton {
  height: 330rpx;
}

.line {
  border-radius: 12rpx;
  height: 24rpx;
}

.line.long { width: 92%; }
.line.short { width: 58%; }
